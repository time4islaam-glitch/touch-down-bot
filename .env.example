# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env for local development.
# On Railway, set these in the dashboard under  Variables → Raw Editor.
#
# ⚠️  NEVER commit a populated .env file to Git.
#     Add ".env" to your .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Telegram Bot token — obtain from @BotFather
TELEGRAM_TOKEN=your-telegram-bot-token-here

# The Telegram chat / channel ID that will receive alerts.
# For a private group: get it via @userinfobot or the getUpdates API.
# Prefix channel IDs with -100, e.g.  -1001234567890
TELEGRAM_CHAT_ID=your-chat-id-here

# ── OPTIONAL — Trading 212 Integration ───────────────────────────────────────

# Your Trading 212 API key (from T212 → Settings → API).
# Leave blank to disable T212 integration (bot still works without it).
TRADING212_API_KEY=

# "live" to use real-money account; "demo" for paper-trading account.
# Defaults to "live" if not set.
T212_ENV=demo

# ── OPTIONAL — Scanner Tuning ─────────────────────────────────────────────────

# How often (in seconds) the market scanner runs.  Default: 3600 (1 hour).
SCAN_INTERVAL=3600

# Minimum hours between two alerts for the same ticker.  Default: 4.
ALERT_COOLDOWN_HOURS=4

# UTC hour when the market scanner starts running.  Default: 13 (09:00 ET).
MARKET_OPEN_UTC=13

# UTC hour when the market scanner stops running.  Default: 21 (17:00 ET).
MARKET_CLOSE_UTC=21

# Filesystem path for the persistent watchlist JSON.  Default: watchlist.json
# On Railway, the working directory is writable so the default is fine.
WATCHLIST_PATH=watchlist.json

# ── OPTIONAL — Universe Scanning ─────────────────────────────────────────────

# Universe scanning mode — scans full exchange instead of watchlist
# Set to "true" to enable. UNIVERSE_MODE=false uses the manual watchlist.
UNIVERSE_MODE=false

# Comma-separated exchanges to scan. Options: NASDAQ, NYSE, LSE
EXCHANGES=NASDAQ,NYSE

# UTC hour to run nightly universe refresh (pre-market). Default: 4 = 04:00 UTC
UNIVERSE_REFRESH_HOUR=4

# Admin Telegram user ID — required to use /refresh command
ADMIN_USER_ID=your_telegram_user_id_here

# Path for candidate ticker list
CANDIDATES_PATH=candidates.json

# ── OPTIONAL — Regime Filter ──────────────────────────────────────────────────

# Regime filter — set to "false" to disable and trade all regimes (v2 behaviour)
# When "true", only fires alerts in BULL_HIGH_VOL and CORRECTION regimes.
REGIME_FILTER=true
